{
  "$schema": "https://railway.com/railway.schema.json",
  "build": {
    "builder": "DOCKERFILE",
    "dockerfilePath": "Dockerfile.engine"
  },
  "deploy": {
    "startCommand": "npx prisma db push --skip-generate && npx tsx src/engine/index.ts",
    "restartPolicyType": "ALWAYS",
    "restartPolicyMaxRetries": 10
  }
}
